# Copy to .env.production before: npm run deploy:hosting
# (Vite bakes VITE_* into the client bundle — never treat these as server-only secrets.)
#
# Firestore security: for each email in VITE_ADMIN_EMAILS, create document
#   bootstrapAdmins/{exact email as doc id}  (empty map is fine) in the Firebase Console
#   so admin role writes in userRoles succeed. Remove after first admin userRoles exist if you prefer.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=moveasy-30eed.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=moveasy-30eed
VITE_FIREBASE_STORAGE_BUCKET=moveasy-30eed.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional — EmailJS (customer/admin/seller emails)
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_INTEREST_TEMPLATE_ID=
VITE_EMAILJS_STATUS_TEMPLATE_ID=
VITE_ADMIN_EMAILS=

# Optional Cloud Functions URLs (profile bootstrap, server-side welcome email)
VITE_CREATE_PROFILE_FUNCTION_URL=
VITE_ONBOARDING_EMAIL_FUNCTION_URL=
VITE_WELCOME_EMAIL_FUNCTION_URL=
