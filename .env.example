VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_WELCOME_EMAIL_FUNCTION_URL=

# Free transactional mail from the browser (welcome + admin signup alert)
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_WELCOME_TEMPLATE_ID=
VITE_EMAILJS_ADMIN_NOTIFY_TEMPLATE_ID=
VITE_ADMIN_NOTIFY_EMAIL=

# Optional: client error reporting (https://sentry.io)
VITE_SENTRY_DSN=

# Optional: Firebase App Check (reCAPTCHA v3 site key from Firebase Console → App Check)
# Local dev: set VITE_APPCHECK_DEBUG_TOKEN=true, run once, copy token from browser console, register in Console → App Check → Manage debug tokens
VITE_APPCHECK_RECAPTCHA_SITE_KEY=
VITE_APPCHECK_DEBUG_TOKEN=
